# Database
DATABASE_URL=postgresql://phantom:phantom@localhost:5432/phantom_msgr

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_me_to_a_secure_random_string_32_chars

# Service HTTP ports (hybrid apps only need /health)
PORT=3000
AUTH_HTTP_PORT=3001
CHAT_HTTP_PORT=3002
MESSAGING_HTTP_PORT=3003
MEDIA_HTTP_PORT=3004
STORY_HTTP_PORT=3005

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=phantom
S3_SECRET_KEY=phantom_secret
S3_BUCKET=phantom-media
S3_PUBLIC_URL=http://localhost:9000
# For mobile clients set S3_PUBLIC_URL to the device-accessible address:
# Android emulator: http://10.0.2.2:9000
# Physical device / LAN: http://<your-machine-ip>:9000

# Firebase (JSON string of service account)
FCM_SERVICE_ACCOUNT=
