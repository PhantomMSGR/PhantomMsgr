{
  "name": "phantom-msgr-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@phantom/sdk": "*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.95.0",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-query-persist-client": "^5.95.0",
    "axios": "^1.7.9",
    "expo": "~55.0.0",
    "expo-audio": "~55.0.9",
    "expo-blur": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "^55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.0",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "hermes-compiler": "^250829098.0.2",
    "hermes-engine": "^0.11.0",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.7.4",
    "socket.io-client": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-native": "~0.73.0",
    "@types/react-test-renderer": "^19.0.0",
    "babel-preset-expo": "^55.0.12",
    "jest-expo": "~55.0.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@phantom/sdk$": "<rootDir>/../../libs/sdk/src/index.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@shopify/flash-list)"
    ]
  },
  "private": true
}
