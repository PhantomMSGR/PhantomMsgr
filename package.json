{
  "name": "phantom-msgr",
  "version": "1.0.0",
  "description": "Anonymous messenger",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:mobile": "node scripts/dev.js --mobile",
    "dev:services": "nx run-many -t serve --projects=tag:type:app,!mobile --parallel=7",
    "dev:infra": "docker compose -f docker-compose.infra.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.infra.yml down",
    "build": "nx run-many -t build --projects=tag:type:app,!mobile --parallel=4",
    "build:affected": "nx affected -t build",
    "test": "nx run-many -t test --parallel=4",
    "test:affected": "nx affected -t test",
    "graph": "nx graph",
    "build:api": "nest build api-gateway",
    "build:auth": "nest build auth-service",
    "build:chat": "nest build chat-service",
    "build:messaging": "nest build messaging-service",
    "build:media": "nest build media-service",
    "build:notifications": "nest build notification-service",
    "build:stories": "nest build story-service",
    "start:api": "nest start api-gateway",
    "start:api:dev": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service",
    "start:auth:dev": "nest start auth-service --watch",
    "start:chat": "nest start chat-service",
    "start:chat:dev": "nest start chat-service --watch",
    "start:messaging": "nest start messaging-service",
    "start:messaging:dev": "nest start messaging-service --watch",
    "start:media": "nest start media-service",
    "start:media:dev": "nest start media-service --watch",
    "start:notifications": "nest start notification-service",
    "start:notifications:dev": "nest start notification-service --watch",
    "start:stories": "nest start story-service",
    "start:stories:dev": "nest start story-service --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "workspaces": [
    "apps/web",
    "libs/sdk"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@nestjs/bull": "^10.2.1",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.3",
    "compression": "^1.7.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.0",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.30.4",
    "jest": "^30.3.0",
    "nx": "^20.8.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.3"
  }
}
